# TrainingEdge — 环境变量配置
# 复制此文件为 .env 并填入实际值

# ── 数据库与存储 ──
TRAININGEDGE_DB_PATH=/data/training_edge.db
TRAININGEDGE_FIT_DIR=/data/fit_files
TRAININGEDGE_LOG_FILE=/data/training_edge.log
TRAININGEDGE_PORT=8420

# ── 运动员参数 ──
TRAININGEDGE_FTP=229
TRAININGEDGE_MAX_HR=192
TRAININGEDGE_RESTING_HR=42

# ── Garmin 同步 ──
GARMINTOKENS=/data/tokens

# ── 访问控制（公网部署必填！）──
TRAININGEDGE_PASSWORD=your-secure-password-here
TRAININGEDGE_SESSION_SECRET=random-hex-string-here

# ── LLM (可选，也可在设置页配置) ──
# 从 https://openrouter.ai/keys 获取
OPENROUTER_API_KEY=
# OPENROUTER_PROXY=socks5://vps-ip:1080

# API 访问密钥（留空自动生成）
TRAININGEDGE_API_KEY=

# ── 时区 ──
TZ=Asia/Shanghai
